  "keyFeatures": [
    "Multi-tenant POS system with per-store isolation",
    "JWT-based authentication with role-based access control",
    "Configurable product catalog with options, extras, and pricing",
    "POS shift management with opening/closing cash reconciliation",
    "Sales recording with payment methods (cash, card, transfer)",
    "Inventory tracking per store with optimistic concurrency",
    "Operational reports and sales analytics",
    "Platform-level management of tenants and stores",
    "Comprehensive audit logging with before/after change tracking",
    "Angular 21 frontend with signals and lazy-loaded feature routes"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/register",
    "POST /api/v1/auth/login",
    "POST /api/v1/auth/refresh",
    "POST /api/v1/pos/sales",
    "POST /api/v1/pos/sales/{saleId}/void",
    "GET /api/v1/pos/shifts/current",
    "POST /api/v1/pos/shifts/open",
    "GET /api/v1/pos/shifts/close-preview",
    "POST /api/v1/pos/shifts/close",
    "GET /api/v1/pos/catalog",
    "GET /api/v1/pos/inventory",
    "GET /api/v1/pos/reports",
    "GET /api/v1/platform/tenants/{tenantId}/stores",
    "PUT /api/v1/platform/stores/{storeId}",
    "PUT /api/v1/platform/tenants/{tenantId}/default-store",
    "GET /api/v1/admin/users",
    "GET /api/v1/admin/roles"
  ]
